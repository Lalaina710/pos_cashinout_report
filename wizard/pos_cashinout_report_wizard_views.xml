<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_pos_cashinout_report_wizard_form" model="ir.ui.view">
        <field name="name">pos.cashinout.report.wizard.form</field>
        <field name="model">pos.cashinout.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Rapport Cash In/Out PdV">
                <group>
                    <group string="Période">
                        <field name="date_from"/>
                        <field name="date_to"/>
                    </group>
                    <group string="Filtres">
                        <field name="pos_config_ids" widget="many2many_tags"/>
                        <field name="movement_type" widget="radio"/>
                        <field name="exclude_session_total"/>
                        <field name="exclude_closing_gap"/>
                        <field name="show_pos_summary"/>
                    </group>
                </group>
                <footer>
                    <button name="action_export_excel" string="Exporter Excel"
                            type="object" class="btn-primary"
                            icon="fa-file-excel-o"/>
                    <button string="Annuler" class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_pos_cashinout_report_wizard" model="ir.actions.act_window">
        <field name="name">Rapport Cash In/Out PdV</field>
        <field name="res_model">pos.cashinout.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_pos_cashinout_report"
              name="Rapport Cash In/Out"
              parent="point_of_sale.menu_point_rep"
              action="action_pos_cashinout_report_wizard"
              sequence="100"/>
</odoo>
